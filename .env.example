SCRAPE_DO_TOKEN=your_scrape_do_token_here
PORT=3000

# Authentication (leave empty to disable authentication)
API_KEY=your_secret_api_key_here
# For multiple API keys, use comma-separated values:
# API_KEYS=key1,key2,key3
# For IP whitelisting (comma-separated, supports wildcards like 192.168.1.*):
# ALLOWED_IPS=127.0.0.1,192.168.1.*

REDIS_URL=redis://localhost:6379
# For Redis with password: redis://:password@localhost:6379
# For Redis with username and password: redis://username:password@localhost:6379
# For TLS: rediss://localhost:6380

# Option 2: Use individual fields (if REDIS_URL is not set)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

DATABASE_URL="postgresql://postgres:password@localhost:5432/internal_linking?schema=public"
WORKER_CONCURRENCY=2
